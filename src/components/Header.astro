---
import Icon from './Icon.astro';
import { recipes } from '../lib/recipes';

const base = import.meta.env.BASE_URL;
const recipeUrls = recipes.map((recipe) => `${base}recipes/${recipe.slug}/`);
---

<header class="site-header">
  <div class="header-inner">
    <a class="brand" href={base} aria-label="You can Cook home">
      <img class="brand-logo" src={`${base}brand/chef-logo.png`} alt="" width="40" height="40" />
      <span class="brand-text">You can Cook</span>
    </a>

    <nav aria-label="Primary navigation">
      <a class="round header-search" href={`${base}#recipe-search`} aria-label="Search recipes" title="Search recipes">
        <Icon name="search" />
        <span>Search</span>
      </a>

      <button
        class="surprise-button"
        id="surprise-me"
        type="button"
        data-recipes={JSON.stringify(recipeUrls)}
        aria-label="Open a random recipe"
      >
        <span aria-hidden="true">✦</span>
        <span>Surprise me</span>
      </button>

      <a class="round add-header" href={`${base}new/`} aria-label="Add recipe">
        <Icon name="plus" />
        <span>Add</span>
      </a>

      <button class="round theme-toggle" id="theme" type="button" aria-label="Theme: Light. Activate for Terracotta." title="Theme: Light">
        <span class="theme-symbol theme-symbol-light" aria-hidden="true">&#9728;</span>
        <span class="theme-symbol theme-symbol-warm" aria-hidden="true">&#9680;</span>
        <span class="theme-symbol theme-symbol-dark" aria-hidden="true">&#9790;</span>
      </button>
    </nav>
  </div>
</header>

<script is:inline>
  (() => {
    const themes = ['light', 'warm', 'dark'];
    const labels = {
      light: 'Light',
      warm: 'Terracotta',
      dark: 'Dark',
    };
    const themeColors = {
      light: '#c7ff57',
      warm: '#e57a3f',
      dark: '#baf64f',
    };
    const button = document.querySelector('#theme');

    const paintThemeButton = () => {
      const current = document.documentElement.dataset.theme || 'light';
      const next = themes[(themes.indexOf(current) + 1) % themes.length];
      button?.setAttribute('title', `Theme: ${labels[current]}`);
      button?.setAttribute('aria-label', `Theme: ${labels[current]}. Activate for ${labels[next]}.`);
      document.querySelector('meta[name="theme-color"]')?.setAttribute('content', themeColors[current]);
    };

    button?.addEventListener('click', () => {
      const current = document.documentElement.dataset.theme || 'light';
      const next = themes[(themes.indexOf(current) + 1) % themes.length];
      document.documentElement.dataset.theme = next;
      localStorage.setItem('theme', next);
      paintThemeButton();
    });

    paintThemeButton();
  })();

  document.querySelector('.header-search')?.addEventListener('click', (event) => {
    const searchInput = document.querySelector('#q');
    if (!searchInput) return;
    event.preventDefault();
    document.querySelector('#recipe-search')?.scrollIntoView({ behavior: 'smooth', block: 'center' });
    window.setTimeout(() => searchInput.focus({ preventScroll: true }), 350);
  });

  document.querySelector('#surprise-me')?.addEventListener('click', (event) => {
    const button = event.currentTarget;
    const recipeUrls = JSON.parse(button.dataset.recipes || '[]');
    if (!recipeUrls.length) return;

    const currentPath = window.location.pathname;
    const alternatives = recipeUrls.filter((url) => !currentPath.endsWith(url));
    const choices = alternatives.length ? alternatives : recipeUrls;
    window.location.assign(choices[Math.floor(Math.random() * choices.length)]);
  });
</script>
