---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Icon from '../../components/Icon.astro';
import { recipes } from '../../lib/recipes';
import '../../styles/photo-upload.css';

export function getStaticPaths() {
  return recipes.map((recipe) => ({ params: { slug: recipe.slug }, props: { recipe } }));
}

const { recipe } = Astro.props;
const repo = import.meta.env.PUBLIC_GITHUB_REPO || 'ucancook/ucancook.github.io';
const base = import.meta.env.BASE_URL;
const canonicalUrl = new URL(`${base}recipes/${recipe.slug}/`, Astro.site || Astro.url.origin).toString();
const socialImage = recipe.photos?.[0]?.src || `${base}brand/chef-logo.png`;
const relatedRecipes = recipes
  .filter((candidate) => candidate.slug !== recipe.slug)
  .map((candidate) => {
    const sharedTags = candidate.tags.filter((tag) => recipe.tags.includes(tag));
    const sharedPrimaryTag = candidate.tags[0] === recipe.tags[0] ? 1 : 0;
    const hasPhoto = candidate.photos?.length ? 1 : 0;
    const score = sharedTags.length * 10 + sharedPrimaryTag * 3 + hasPhoto;

    return { recipe: candidate, sharedTags, score };
  })
  .filter((item) => item.sharedTags.length > 0)
  .sort((a, b) =>
    b.score - a.score ||
    a.recipe.title.localeCompare(b.recipe.title)
  )
  .slice(0, 3);
const imageUrls = recipe.photos?.map((photo) => new URL(photo.src, Astro.site || Astro.url.origin).toString()) || [];
const suggestedPhotoFilename = `${recipe.slug}.jpg`;
const photoUploadUrl = `https://github.com/${repo}/upload/main/public/images/recipes`;
const schema = {
  '@context': 'https://schema.org',
  '@type': 'Recipe',
  name: recipe.title,
  description: recipe.description,
  image: imageUrls.length ? imageUrls : undefined,
  dateModified: recipe.updated,
  recipeYield: `${recipe.servings} servings`,
  prepTime: `PT${recipe.prepMinutes}M`,
  cookTime: `PT${recipe.cookMinutes}M`,
  totalTime: `PT${recipe.prepMinutes + recipe.cookMinutes}M`,
  recipeCategory: recipe.tags[0],
  recipeCuisine: recipe.tags.find((tag) => ['Indian', 'Italian', 'Mexican', 'Asian', 'Mediterranean', 'Middle Eastern', 'American'].includes(tag)),
  keywords: recipe.tags.join(', '),
  nutrition: recipe.calories ? { '@type': 'NutritionInformation', calories: `${recipe.calories} calories` } : undefined,
  recipeIngredient: recipe.ingredients.map((item) => `${item.amount} ${item.item}${item.note ? `, ${item.note}` : ''}`),
  recipeInstructions: recipe.steps.map((step) => ({ '@type': 'HowToStep', text: step })),
  url: canonicalUrl,
};
---

<BaseLayout title={`${recipe.title} - You can Cook`} description={recipe.description} image={socialImage} canonical={canonicalUrl} type="article">
  <script type="application/ld+json" set:html={JSON.stringify(schema)}></script>

  <section class="hero recipe-hero">
    <a class="eyebrow" href={base}>← All recipes</a>
    <div class="recipe-title-row">
      <h1>{recipe.title}</h1>
      <button class="favorite-button recipe-favorite" type="button" data-favorite-slug={recipe.slug} aria-pressed="false" aria-label="Add to favorites"><Icon name="heart" size={24} /><span data-favorite-label>Save</span></button>
    </div>
    <p class="lede">{recipe.description}</p>
    <div class="meta"><Icon name="clock" size={17} />{recipe.prepMinutes + recipe.cookMinutes} minutes · {recipe.servings} servings {recipe.calories && `· ${recipe.calories} kcal`}</div>
    <div class="tags recipe-tags">{recipe.tags.map((tag) => <span class="pill">{tag}</span>)}</div>
    <div class="recipe-actions">
      <button class="btn primary" id="cook-mode-open" type="button"><Icon name="cook" /> Cooking mode</button>
      <button
        class="btn secondary shopping-list-toggle"
        id="shopping-list-toggle"
        type="button"
        data-recipe-slug={recipe.slug}
        data-recipe-title={recipe.title}
        data-recipe-ingredients={JSON.stringify(recipe.ingredients)}
        aria-pressed="false"
      >
        <span aria-hidden="true">+</span>
        <span data-shopping-label>Add to shopping list</span>
      </button>
      <button class="btn secondary" id="share-recipe" type="button"><Icon name="share" /> Share</button>
      <button class="btn secondary" id="print-recipe" type="button"><Icon name="print" /> Print</button>
    </div>
  </section>

  <section class="photo-gallery" aria-label={`${recipe.title} photos`}>
    {recipe.photos?.length ? recipe.photos.map((photo, index) => (
      <figure class:list={{ 'recipe-photo': true, featured: index === 0 }}>
        <img src={photo.src} alt={photo.alt || recipe.title} loading={index === 0 ? 'eager' : 'lazy'} />
        {photo.credit && <figcaption>{photo.credit}</figcaption>}
      </figure>
    )) : (
      <figure class="recipe-photo featured photo-placeholder-large">
        <img src={`${base}brand/chef-logo.png`} alt="" />
        <figcaption>No photo yet — add one when you cook this recipe.</figcaption>
      </figure>
    )}
  </section>

  <div class="recipe-grid">
    <section class="panel box method-panel">
      <div class="eyebrow">Method</div>
      <h2>Make it</h2>
      <ol class="steps">{recipe.steps.map((step) => <li>{step}</li>)}</ol>
      {recipe.notes?.map((note) => <p class="lede recipe-note">{note}</p>)}
    </section>

    <aside class="panel box ingredients">
      <div class="eyebrow">The important part</div>
      <h2>Ingredients</h2>
      <div class="ingredient-heading-row">
        <p class="ingredient-hint">Tap ingredients to check them off while cooking.</p>
        <div
          class="serving-control"
          id="recipe-serving-control"
          data-serving-slug={recipe.slug}
          data-base-servings={recipe.servings}
          aria-label="Adjust servings"
        >
          <span>Servings</span>
          <button type="button" data-serving-action="decrease" aria-label="Decrease servings">&minus;</button>
          <strong data-serving-value>{recipe.servings}</strong>
          <button type="button" data-serving-action="increase" aria-label="Increase servings">+</button>
        </div>
      </div>
      <ul>{recipe.ingredients.map((item, index) => (
        <li class="ingredient-check-row">
          <label>
            <input type="checkbox" class="ingredient-check" data-index={index} />
            <span class="amount" data-scalable-amount data-base-amount={item.amount}>{item.amount}</span>
            <span>{item.item}{item.note && <small class="note">{item.note}</small>}</span>
          </label>
        </li>
      ))}</ul>
    </aside>
  </div>

  {relatedRecipes.length > 0 && (
    <section class="related-recipes" aria-labelledby="related-recipes-title">
      <div class="related-recipes-heading">
        <div>
          <div class="eyebrow">Keep cooking</div>
          <h2 id="related-recipes-title">Related recipes</h2>
        </div>
        <a class="text-link" href={base}>Browse all recipes</a>
      </div>

      <div class="related-recipes-grid">
        {relatedRecipes.map(({ recipe: related, sharedTags }) => (
          <article class="related-recipe-card">
            <a class="related-recipe-link" href={`${base}recipes/${related.slug}/`}>
              {related.photos?.[0] ? (
                <img
                  class="related-recipe-photo"
                  src={related.photos[0].src}
                  alt={related.photos[0].alt || related.title}
                  loading="lazy"
                />
              ) : (
                <div class="related-recipe-placeholder" aria-hidden="true">
                  <img src={`${base}brand/chef-logo.png`} alt="" loading="lazy" />
                </div>
              )}

              <div class="related-recipe-copy">
                <div class="related-recipe-tags">
                  {sharedTags.slice(0, 2).map((tag) => <span>{tag}</span>)}
                </div>
                <h3>{related.title}</h3>
                <p>{related.description}</p>
                <div class="related-recipe-meta">
                  <span>{related.prepMinutes + related.cookMinutes} min</span>
                  <span>{related.ingredients.length} ingredients</span>
                </div>
              </div>
            </a>
          </article>
        ))}
      </div>
    </section>
  )}
  <section class="panel photo-upload-panel" aria-labelledby="photo-upload-title">
    <div class="photo-upload-copy">
      <div class="eyebrow">Cooked it?</div>
      <h2 id="photo-upload-title">Add a photo here</h2>
      <p>Rename the image exactly as shown below, then upload it to the recipe image folder on GitHub.</p>
      <div class="photo-filename-row">
        <code id="photo-filename">{suggestedPhotoFilename}</code>
        <button class="btn secondary photo-copy-button" id="copy-photo-filename" type="button" aria-label={`Copy ${suggestedPhotoFilename}`}>
          <Icon name="copy" />
          <span>Copy filename</span>
        </button>
      </div>
      <p class="photo-upload-note">Use a JPG image. The filename must match exactly, including lowercase letters and <strong>.jpg</strong>.</p>
    </div>
    <a class="btn primary photo-upload-link" href={photoUploadUrl} target="_blank" rel="noreferrer">
      Add photo here
    </a>
  </section>

  <div class="recipe-footer-actions">
    <a class="edit" href={`https://github.com/${repo}/edit/main/src/content/recipes/${recipe.slug}.json`} target="_blank"><Icon name="edit" />Edit this recipe on GitHub</a>
  </div>

  <a class="fab" href={`${base}new/`}><Icon name="plus" /><span>Add recipe</span></a>

  <dialog class="cook-mode" id="cook-mode" aria-labelledby="cook-mode-title">
    <div class="cook-mode-shell">
      <header class="cook-mode-header">
        <div><div class="eyebrow">Cooking mode</div><h2 id="cook-mode-title">{recipe.title}</h2></div>
        <button class="round" id="cook-mode-close" type="button" aria-label="Close cooking mode"><Icon name="close" /></button>
      </header>
      <div class="cook-mode-body">
        <aside class="cook-ingredients">
          <h3>Ingredients</h3>
          <ul>{recipe.ingredients.map((item, index) => (
            <li><label><input type="checkbox" class="cook-ingredient-check" data-index={index} /><span><strong data-scalable-amount data-base-amount={item.amount}>{item.amount}</strong> {item.item}{item.note && <small>{item.note}</small>}</span></label></li>
          ))}</ul>
        </aside>
        <section class="cook-step-panel">
          <div class="cook-progress"><span id="cook-step-count">Step 1 of {recipe.steps.length}</span><progress id="cook-progress" max={recipe.steps.length} value="1"></progress></div>
          <ol class="cook-steps">{recipe.steps.map((step, index) => <li data-cook-step={index} hidden={index !== 0}><span class="cook-step-number">{index + 1}</span><p>{step}</p></li>)}</ol>
          <div class="cook-navigation">
            <button class="btn secondary" id="cook-prev" type="button"><Icon name="left" /> Previous</button>
            <button class="btn primary" id="cook-next" type="button">Next <Icon name="right" /></button>
          </div>
        </section>
      </div>
    </div>
  </dialog>
</BaseLayout>

<script define:vars={{ recipeTitle: recipe.title, recipeDescription: recipe.description, recipeSlug: recipe.slug, suggestedPhotoFilename }}>
  const servingPreferenceKey = 'you-can-cook-serving-preferences';
  const servingControl = document.querySelector('#recipe-serving-control');
  const servingSlug = servingControl?.dataset.servingSlug || recipeSlug;
  const baseServings = Math.max(1, Number(servingControl?.dataset.baseServings || 1));

  const readServingPreferences = () => {
    try {
      const value = JSON.parse(localStorage.getItem(servingPreferenceKey) || '{}');
      return value && typeof value === 'object' ? value : {};
    } catch {
      return {};
    }
  };

  const saveServingPreference = (servings) => {
    const preferences = readServingPreferences();
    preferences[servingSlug] = servings;
    localStorage.setItem(servingPreferenceKey, JSON.stringify(preferences));
    window.dispatchEvent(new CustomEvent('servings-changed', {
      detail: { slug: servingSlug, servings },
    }));
  };

  const fractionGlyphs = {
    'Â¼': 1 / 4, 'Â½': 1 / 2, 'Â¾': 3 / 4,
    'â…“': 1 / 3, 'â…”': 2 / 3,
    'â…›': 1 / 8, 'â…œ': 3 / 8, 'â…': 5 / 8, 'â…ž': 7 / 8,
  };

  const parseNumberToken = (token) => {
    const value = String(token || '').trim();
    if (!value) return null;

    if (fractionGlyphs[value] != null) return fractionGlyphs[value];

    const glyphMatch = value.match(/^(\d+)?([Â¼Â½Â¾â…“â…”â…›â…œâ…â…ž])$/);
    if (glyphMatch) {
      return Number(glyphMatch[1] || 0) + fractionGlyphs[glyphMatch[2]];
    }

    const mixed = value.match(/^(\d+)\s+(\d+)\/(\d+)$/);
    if (mixed) return Number(mixed[1]) + Number(mixed[2]) / Number(mixed[3]);

    const fraction = value.match(/^(\d+)\/(\d+)$/);
    if (fraction) return Number(fraction[1]) / Number(fraction[2]);

    const number = Number(value);
    return Number.isFinite(number) ? number : null;
  };

  const gcd = (a, b) => b ? gcd(b, a % b) : a;

  const formatScaledNumber = (value) => {
    if (!Number.isFinite(value)) return '';
    if (Math.abs(value - Math.round(value)) < 0.001) return String(Math.round(value));

    const eighths = Math.round(value * 8);
    if (Math.abs(value - eighths / 8) < 0.025) {
      const whole = Math.floor(eighths / 8);
      const numerator = eighths % 8;
      if (!numerator) return String(whole);
      const divisor = gcd(numerator, 8);
      const fraction = `${numerator / divisor}/${8 / divisor}`;
      return whole ? `${whole} ${fraction}` : fraction;
    }

    return String(Math.round(value * 100) / 100);
  };

  const scaleAmount = (amount, factor) => {
    const original = String(amount || '').trim();
    if (!original || Math.abs(factor - 1) < 0.001) return original;

    const range = original.match(/^(\d+(?:\.\d+)?|\d+\s+\d+\/\d+|\d+\/\d+|\d*[Â¼Â½Â¾â…“â…”â…›â…œâ…â…ž])\s*([â€“-])\s*(\d+(?:\.\d+)?|\d+\s+\d+\/\d+|\d+\/\d+|\d*[Â¼Â½Â¾â…“â…”â…›â…œâ…â…ž])(.*)$/);
    if (range) {
      const first = parseNumberToken(range[1]);
      const second = parseNumberToken(range[3]);
      if (first != null && second != null) {
        return `${formatScaledNumber(first * factor)}${range[2]}${formatScaledNumber(second * factor)}${range[4]}`;
      }
    }

    const leading = original.match(/^(\d+(?:\.\d+)?|\d+\s+\d+\/\d+|\d+\/\d+|\d*[Â¼Â½Â¾â…“â…”â…›â…œâ…â…ž])(.*)$/);
    if (!leading) return original;

    const numeric = parseNumberToken(leading[1]);
    return numeric == null
      ? original
      : `${formatScaledNumber(numeric * factor)}${leading[2]}`;
  };

  const applyRecipeServings = (servings, persist = true) => {
    const next = Math.max(1, Math.min(24, Math.round(Number(servings) || baseServings)));
    const factor = next / baseServings;

    document.querySelectorAll('[data-scalable-amount]').forEach((element) => {
      element.textContent = scaleAmount(element.dataset.baseAmount || '', factor);
    });

    document.querySelectorAll('[data-serving-value]').forEach((element) => {
      element.textContent = String(next);
    });

    document.querySelectorAll('[data-recipe-serving-meta]').forEach((element) => {
      element.textContent = String(next);
    });

    servingControl?.querySelector('[data-serving-action="decrease"]')
      ?.toggleAttribute('disabled', next <= 1);
    servingControl?.querySelector('[data-serving-action="increase"]')
      ?.toggleAttribute('disabled', next >= 24);

    if (persist) saveServingPreference(next);
    return next;
  };

  servingControl?.addEventListener('click', (event) => {
    const button = event.target.closest('[data-serving-action]');
    if (!button) return;

    const current = Number(servingControl.querySelector('[data-serving-value]')?.textContent || baseServings);
    applyRecipeServings(button.dataset.servingAction === 'increase' ? current + 1 : current - 1);
  });

  const initialServingPreference = readServingPreferences()[servingSlug] || baseServings;
  applyRecipeServings(initialServingPreference, false);
  const shoppingKey = 'you-can-cook-shopping-recipes';
  const shoppingButton = document.querySelector('#shopping-list-toggle');

  const getShoppingRecipes = () => {
    try {
      const stored = JSON.parse(localStorage.getItem(shoppingKey) || '[]');
      return Array.isArray(stored) ? stored : [];
    } catch {
      return [];
    }
  };

  const saveShoppingRecipes = (items) => {
    localStorage.setItem(shoppingKey, JSON.stringify(items));
    window.dispatchEvent(new CustomEvent('shopping-list-changed'));
  };

  const paintShoppingButton = () => {
    if (!shoppingButton) return;
    const slug = shoppingButton.dataset.recipeSlug;
    const added = getShoppingRecipes().some((item) => item.slug === slug);
    const label = shoppingButton.querySelector('[data-shopping-label]');
    shoppingButton.classList.toggle('active', added);
    shoppingButton.setAttribute('aria-pressed', String(added));
    if (label) label.textContent = added ? 'Remove from shopping list' : 'Add to shopping list';
  };

  shoppingButton?.addEventListener('click', () => {
    const slug = shoppingButton.dataset.recipeSlug;
    const title = shoppingButton.dataset.recipeTitle;
    const ingredients = JSON.parse(shoppingButton.dataset.recipeIngredients || '[]');
    const items = getShoppingRecipes();
    const existingIndex = items.findIndex((item) => item.slug === slug);

    if (existingIndex >= 0) {
      items.splice(existingIndex, 1);
    } else {
      items.push({ slug, title, ingredients, servings: baseServings });
    }

    saveShoppingRecipes(items);
    paintShoppingButton();
  });

  paintShoppingButton();
  window.addEventListener('shopping-list-changed', paintShoppingButton);
  const shareButton = document.querySelector('#share-recipe');
  const printButton = document.querySelector('#print-recipe');
  const photoCopyButton = document.querySelector('#copy-photo-filename');

  shareButton?.addEventListener('click', async () => {
    const data = { title: recipeTitle, text: recipeDescription, url: window.location.href };
    try {
      if (navigator.share) await navigator.share(data);
      else { await navigator.clipboard.writeText(window.location.href); shareButton.textContent = 'Link copied'; }
    } catch (error) { if (error?.name !== 'AbortError') shareButton.textContent = 'Could not share'; }
  });
  printButton?.addEventListener('click', () => window.print());

  photoCopyButton?.addEventListener('click', async () => {
    try {
      await navigator.clipboard.writeText(suggestedPhotoFilename);
      const label = photoCopyButton.querySelector('span');
      if (label) label.textContent = 'Copied';
      window.setTimeout(() => { if (label) label.textContent = 'Copy filename'; }, 1800);
    } catch {
      const filename = document.querySelector('#photo-filename');
      const selection = window.getSelection();
      const range = document.createRange();
      if (filename && selection) {
        range.selectNodeContents(filename);
        selection.removeAllRanges();
        selection.addRange(range);
      }
    }
  });

  const dialog = document.querySelector('#cook-mode');
  const openButton = document.querySelector('#cook-mode-open');
  const closeButton = document.querySelector('#cook-mode-close');
  const steps = [...document.querySelectorAll('[data-cook-step]')];
  const prev = document.querySelector('#cook-prev');
  const next = document.querySelector('#cook-next');
  const count = document.querySelector('#cook-step-count');
  const progress = document.querySelector('#cook-progress');
  let currentStep = 0;
  let wakeLock = null;

  const syncChecks = (source) => {
    const index = source.dataset.index;
    document.querySelectorAll(`.ingredient-check[data-index="${index}"], .cook-ingredient-check[data-index="${index}"]`).forEach((box) => { box.checked = source.checked; });
  };
  document.querySelectorAll('.ingredient-check, .cook-ingredient-check').forEach((box) => box.addEventListener('change', () => syncChecks(box)));

  const showStep = (index) => {
    currentStep = Math.max(0, Math.min(index, steps.length - 1));
    steps.forEach((step, i) => { step.hidden = i !== currentStep; });
    count.textContent = `Step ${currentStep + 1} of ${steps.length}`;
    progress.value = currentStep + 1;
    prev.disabled = currentStep === 0;
    next.innerHTML = currentStep === steps.length - 1 ? 'Finish' : 'Next <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>';
  };
  const requestWakeLock = async () => { try { if ('wakeLock' in navigator) wakeLock = await navigator.wakeLock.request('screen'); } catch {} };
  const releaseWakeLock = async () => { try { await wakeLock?.release(); } catch {} wakeLock = null; };

  openButton?.addEventListener('click', async () => { showStep(0); dialog.showModal(); await requestWakeLock(); });
  closeButton?.addEventListener('click', () => dialog.close());
  dialog?.addEventListener('click', (event) => { if (event.target === dialog) dialog.close(); });
  dialog?.addEventListener('close', releaseWakeLock);
  prev?.addEventListener('click', () => showStep(currentStep - 1));
  next?.addEventListener('click', () => currentStep === steps.length - 1 ? dialog.close() : showStep(currentStep + 1));
  document.addEventListener('visibilitychange', () => { if (document.visibilityState === 'visible' && dialog?.open) requestWakeLock(); });
  showStep(0);
</script>
