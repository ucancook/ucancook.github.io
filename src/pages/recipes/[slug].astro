---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Icon from '../../components/Icon.astro';
import { recipes } from '../../lib/recipes';

export function getStaticPaths() {
  return recipes.map((recipe) => ({ params: { slug: recipe.slug }, props: { recipe } }));
}

const { recipe } = Astro.props;
const repo = import.meta.env.PUBLIC_GITHUB_REPO || 'youcancook/youcancook.github.io';
const base = import.meta.env.BASE_URL;
const canonicalUrl = new URL(`${base}recipes/${recipe.slug}/`, Astro.site || Astro.url.origin).toString();
const imageUrls = recipe.photos?.map((photo) => new URL(photo.src, Astro.site || Astro.url.origin).toString()) || [];
const schema = {
  '@context': 'https://schema.org',
  '@type': 'Recipe',
  name: recipe.title,
  description: recipe.description,
  image: imageUrls.length ? imageUrls : undefined,
  dateModified: recipe.updated,
  recipeYield: `${recipe.servings} servings`,
  prepTime: `PT${recipe.prepMinutes}M`,
  cookTime: `PT${recipe.cookMinutes}M`,
  totalTime: `PT${recipe.prepMinutes + recipe.cookMinutes}M`,
  recipeCategory: recipe.tags[0],
  recipeCuisine: recipe.tags.find((tag) => ['Indian', 'Italian', 'Mexican', 'Asian', 'Mediterranean', 'Middle Eastern', 'American'].includes(tag)),
  keywords: recipe.tags.join(', '),
  nutrition: recipe.calories ? { '@type': 'NutritionInformation', calories: `${recipe.calories} calories` } : undefined,
  recipeIngredient: recipe.ingredients.map((item) => `${item.amount} ${item.item}${item.note ? `, ${item.note}` : ''}`),
  recipeInstructions: recipe.steps.map((step) => ({ '@type': 'HowToStep', text: step })),
  url: canonicalUrl,
};
---

<BaseLayout title={`${recipe.title} — You can Cook`} description={recipe.description}>
  <script type="application/ld+json" set:html={JSON.stringify(schema)}></script>

  <section class="hero recipe-hero">
    <a class="eyebrow" href={base}>← All recipes</a>
    <div class="recipe-title-row">
      <h1>{recipe.title}</h1>
      <button class="favorite-button recipe-favorite" type="button" data-favorite-slug={recipe.slug} aria-pressed="false" aria-label="Add to favorites"><Icon name="heart" size={24} /><span data-favorite-label>Save</span></button>
    </div>
    <p class="lede">{recipe.description}</p>
    <div class="meta"><Icon name="clock" size={17} />{recipe.prepMinutes + recipe.cookMinutes} minutes · {recipe.servings} servings {recipe.calories && `· ${recipe.calories} kcal`}</div>
    <div class="tags recipe-tags">{recipe.tags.map((tag) => <span class="pill">{tag}</span>)}</div>
    <div class="recipe-actions">
      <button class="btn primary" id="cook-mode-open" type="button"><Icon name="cook" /> Cooking mode</button>
      <button class="btn secondary" id="share-recipe" type="button"><Icon name="share" /> Share</button>
      <button class="btn secondary" id="print-recipe" type="button"><Icon name="print" /> Print</button>
    </div>
  </section>

  <section class="photo-gallery" aria-label={`${recipe.title} photos`}>
    {recipe.photos?.length ? recipe.photos.map((photo, index) => (
      <figure class:list={{ 'recipe-photo': true, featured: index === 0 }}>
        <img src={photo.src} alt={photo.alt || recipe.title} loading={index === 0 ? 'eager' : 'lazy'} />
        {photo.credit && <figcaption>{photo.credit}</figcaption>}
      </figure>
    )) : (
      <figure class="recipe-photo featured photo-placeholder-large">
        <img src={`${base}brand/chef-logo.png`} alt="" />
        <figcaption>No photo yet — add one when you cook this recipe.</figcaption>
      </figure>
    )}
  </section>

  <div class="recipe-grid">
    <section class="panel box method-panel">
      <div class="eyebrow">Method</div>
      <h2>Make it</h2>
      <ol class="steps">{recipe.steps.map((step) => <li>{step}</li>)}</ol>
      {recipe.notes?.map((note) => <p class="lede recipe-note">{note}</p>)}
    </section>

    <aside class="panel box ingredients">
      <div class="eyebrow">The important part</div>
      <h2>Ingredients</h2>
      <p class="ingredient-hint">Tap ingredients to check them off while cooking.</p>
      <ul>{recipe.ingredients.map((item, index) => (
        <li class="ingredient-check-row">
          <label>
            <input type="checkbox" class="ingredient-check" data-index={index} />
            <span class="amount">{item.amount}</span>
            <span>{item.item}{item.note && <small class="note">{item.note}</small>}</span>
          </label>
        </li>
      ))}</ul>
    </aside>
  </div>

  <div class="recipe-footer-actions">
    <a class="edit" href={`https://github.com/${repo}/edit/main/src/content/recipes/${recipe.slug}.json`} target="_blank"><Icon name="edit" />Edit this recipe on GitHub</a>
  </div>

  <a class="fab" href={`${base}new/`}><Icon name="plus" /><span>Add recipe</span></a>

  <dialog class="cook-mode" id="cook-mode" aria-labelledby="cook-mode-title">
    <div class="cook-mode-shell">
      <header class="cook-mode-header">
        <div><div class="eyebrow">Cooking mode</div><h2 id="cook-mode-title">{recipe.title}</h2></div>
        <button class="round" id="cook-mode-close" type="button" aria-label="Close cooking mode"><Icon name="close" /></button>
      </header>
      <div class="cook-mode-body">
        <aside class="cook-ingredients">
          <h3>Ingredients</h3>
          <ul>{recipe.ingredients.map((item, index) => (
            <li><label><input type="checkbox" class="cook-ingredient-check" data-index={index} /><span><strong>{item.amount}</strong> {item.item}{item.note && <small>{item.note}</small>}</span></label></li>
          ))}</ul>
        </aside>
        <section class="cook-step-panel">
          <div class="cook-progress"><span id="cook-step-count">Step 1 of {recipe.steps.length}</span><progress id="cook-progress" max={recipe.steps.length} value="1"></progress></div>
          <ol class="cook-steps">{recipe.steps.map((step, index) => <li data-cook-step={index} hidden={index !== 0}><span class="cook-step-number">{index + 1}</span><p>{step}</p></li>)}</ol>
          <div class="cook-navigation">
            <button class="btn secondary" id="cook-prev" type="button"><Icon name="left" /> Previous</button>
            <button class="btn primary" id="cook-next" type="button">Next <Icon name="right" /></button>
          </div>
        </section>
      </div>
    </div>
  </dialog>
</BaseLayout>

<script define:vars={{ recipeTitle: recipe.title, recipeDescription: recipe.description, recipeSlug: recipe.slug }}>
  const shareButton = document.querySelector('#share-recipe');
  const printButton = document.querySelector('#print-recipe');
  shareButton?.addEventListener('click', async () => {
    const data = { title: recipeTitle, text: recipeDescription, url: window.location.href };
    try {
      if (navigator.share) await navigator.share(data);
      else { await navigator.clipboard.writeText(window.location.href); shareButton.textContent = 'Link copied'; }
    } catch (error) { if (error?.name !== 'AbortError') shareButton.textContent = 'Could not share'; }
  });
  printButton?.addEventListener('click', () => window.print());

  const dialog = document.querySelector('#cook-mode');
  const openButton = document.querySelector('#cook-mode-open');
  const closeButton = document.querySelector('#cook-mode-close');
  const steps = [...document.querySelectorAll('[data-cook-step]')];
  const prev = document.querySelector('#cook-prev');
  const next = document.querySelector('#cook-next');
  const count = document.querySelector('#cook-step-count');
  const progress = document.querySelector('#cook-progress');
  let currentStep = 0;
  let wakeLock = null;

  const syncChecks = (source) => {
    const index = source.dataset.index;
    document.querySelectorAll(`.ingredient-check[data-index="${index}"], .cook-ingredient-check[data-index="${index}"]`).forEach((box) => { box.checked = source.checked; });
  };
  document.querySelectorAll('.ingredient-check, .cook-ingredient-check').forEach((box) => box.addEventListener('change', () => syncChecks(box)));

  const showStep = (index) => {
    currentStep = Math.max(0, Math.min(index, steps.length - 1));
    steps.forEach((step, i) => { step.hidden = i !== currentStep; });
    count.textContent = `Step ${currentStep + 1} of ${steps.length}`;
    progress.value = currentStep + 1;
    prev.disabled = currentStep === 0;
    next.innerHTML = currentStep === steps.length - 1 ? 'Finish' : 'Next <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>';
  };
  const requestWakeLock = async () => { try { if ('wakeLock' in navigator) wakeLock = await navigator.wakeLock.request('screen'); } catch {} };
  const releaseWakeLock = async () => { try { await wakeLock?.release(); } catch {} wakeLock = null; };

  openButton?.addEventListener('click', async () => { showStep(0); dialog.showModal(); await requestWakeLock(); });
  closeButton?.addEventListener('click', () => dialog.close());
  dialog?.addEventListener('click', (event) => { if (event.target === dialog) dialog.close(); });
  dialog?.addEventListener('close', releaseWakeLock);
  prev?.addEventListener('click', () => showStep(currentStep - 1));
  next?.addEventListener('click', () => currentStep === steps.length - 1 ? dialog.close() : showStep(currentStep + 1));
  document.addEventListener('visibilitychange', () => { if (document.visibilityState === 'visible' && dialog?.open) requestWakeLock(); });
  showStep(0);
</script>
