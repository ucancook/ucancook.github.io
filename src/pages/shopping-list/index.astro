---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { recipes } from '../../lib/recipes';

const base = import.meta.env.BASE_URL;
const recipeIndex = recipes.map((recipe) => ({
  slug: recipe.slug,
  title: recipe.title,
  servings: recipe.servings,
  ingredients: recipe.ingredients,
}));
---

<BaseLayout
  title="Shopping list - You can Cook"
  description="A combined shopping checklist made from one or more recipes."
>
  <section class="hero shopping-list-hero">
    <a class="eyebrow" href={base}>&larr; All recipes</a>
    <h1>Shopping list</h1>
    <p class="lede">Combine ingredients from several recipes into one practical checklist.</p>
  </section>

  <section class="shopping-list-shell" data-recipe-index={JSON.stringify(recipeIndex)}>
    <div class="shopping-list-toolbar">
      <div>
        <div class="eyebrow">Selected recipes</div>
        <p class="shopping-list-summary" id="shopping-list-summary">No recipes added yet.</p>
      </div>

      <div class="shopping-list-toolbar-actions">
        <button class="btn secondary" id="shopping-copy" type="button">Copy list</button>
        <button class="btn secondary" id="shopping-clear-checked" type="button">Clear checked</button>
        <button class="btn secondary shopping-clear-all" id="shopping-clear-all" type="button">Clear all</button>
      </div>
    </div>

    <div class="shopping-selected-recipes" id="shopping-selected-recipes"></div>

    <div class="shopping-empty panel box" id="shopping-empty">
      <div class="shopping-empty-icon" aria-hidden="true">&#9783;</div>
      <h2>Your list is empty</h2>
      <p>Add ingredients from any recipe page. Recipes can be combined and matching ingredient names will be grouped together.</p>
      <a class="btn primary" href={base}>Browse recipes</a>
    </div>

    <div class="shopping-groups" id="shopping-groups" hidden></div>
  </section>
</BaseLayout>

<script define:vars={{ base }}>
  const storageKey = 'you-can-cook-shopping-recipes';
  const checkedKey = 'you-can-cook-shopping-checked';
  const servingKey = 'you-can-cook-serving-preferences';
  const shell = document.querySelector('.shopping-list-shell');
